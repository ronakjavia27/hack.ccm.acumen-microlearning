# hack.CCM API Keys Configuration
# ================================
# At least ONE key is required. Copy this file to .env and fill in your keys.

# Primary Gemini API key (required - used for main LLM calls)
PRIMARY_GEMINI_API_KEY=your_gemini_api_key_here

# Backup Gemini API key (optional - fallback if primary is rate-limited)
BACKUP_GEMINI_API_KEY=your_backup_gemini_api_key_here

# Together AI API key (optional - used for pearl extraction with cheaper models)
TOGETHER_API_KEY=your_together_api_key_here

# DeepSeek API key (optional - used for schema extraction)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
