# hack.CCM API Keys Configuration
# ================================
# At least ONE key is required. Copy this file to .env and fill in your keys.

# OpenRouter API key (recommended - used by default for Pass 1 extraction)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Primary Gemini API key (optional - used when --llm gemini)
PRIMARY_GEMINI_API_KEY=your_gemini_api_key_here

# Backup Gemini API key (optional - fallback if primary is rate-limited)
BACKUP_GEMINI_API_KEY=your_backup_gemini_api_key_here

# Together AI API key (optional - used when --llm together for pearl extraction)
TOGETHER_API_KEY=your_together_api_key_here

# DeepSeek API key (optional - only used by --llm together fallback chain)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# OpenRouter API key (optional - used for flashcard generation)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=tencent/hy3:free
